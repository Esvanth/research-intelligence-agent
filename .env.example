# ─────────────────────────────────────────────────────────────────────────────
# Research Intelligence Agent — Environment Configuration
# ─────────────────────────────────────────────────────────────────────────────
# HOW TO FILL THIS IN:
# 1. Copy this file:  cp .env.example .env
# 2. Fill in each value below (remove the placeholder text)
# 3. NEVER commit your .env file to GitHub
# ─────────────────────────────────────────────────────────────────────────────

# Azure AI Foundry Project Endpoint
# WHERE TO GET IT: portal.azure.com → AI Foundry → your project → Overview page
# FORMAT: https://<resource-name>.services.ai.azure.com/api/projects/<project-name>
AZURE_AI_FOUNDRY_PROJECT_ENDPOINT=https://YOUR-RESOURCE.services.ai.azure.com/api/projects/YOUR-PROJECT

# Model Deployment Name
# WHERE TO GET IT: Foundry project → Models + Endpoints → copy deployment name
# DEFAULT: gpt-4o (keep this unless you deployed a different model)
AZURE_AI_MODEL_DEPLOYMENT=gpt-4o

# Grounding with Bing Search Connection Name
# WHERE TO GET IT: Foundry project → Settings → Connections → your Bing connection name
# NOTE: Bing Search API v7 is RETIRED. Use Grounding with Bing Search instead.
BING_CONNECTION_NAME=research-bing-grounding

# Optional Settings (defaults are fine, change only if needed)
MAX_SEARCH_RESULTS=5
MAX_AGENTS_ITERATIONS=10
LOG_LEVEL=INFO
